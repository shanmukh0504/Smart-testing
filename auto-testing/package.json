{
  "name": "auto-testing-agent",
  "version": "1.0.0",
  "description": "AI-powered automatic testing agent for frontend and backend",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "auto-test": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "bootstrap": "tsx src/cli.ts bootstrap",
    "generate": "tsx src/cli.ts generate",
    "test": "tsx src/cli.ts generate-and-run",
    "test:run": "tsx src/cli.ts run",
    "server": "tsx src/cli.ts server",
    "report": "tsx src/cli.ts report",
    "test:ui": "playwright test",
    "test:api": "vitest run --config vitest.api.config.ts"
  },
  "keywords": [
    "testing",
    "ai",
    "playwright",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@playwright/test": "^1.49.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "glob": "^13.0.6",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
