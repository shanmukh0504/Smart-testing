# Git provider: "github" or "gitea"
GIT_PROVIDER=gitea

# For Gitea: base URL of your Gitea instance (e.g. https://version.btcfi.wtf)
# For GitHub: leave empty to use https://api.github.com, or set for GitHub Enterprise
GIT_BASE_URL=https://version.btcfi.wtf

# Organization/owner name
GIT_ORG=hashiraio

# Personal access token (Gitea or GitHub)
GIT_TOKEN=your_token_here

# Anthropic Claude API (for AI-powered test generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514
